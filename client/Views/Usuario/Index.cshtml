@using Domain.Usuarios
@using Domain.Usuarios.Roles

@model Usuario;
@{
    ViewData["Title"] = "Mi perfil";
    IEnumerable<Usuario>? Equipo = ViewData["ListaEquipo"] as IEnumerable<Usuario>;
}

<section class="userDisplay">
    <h2>@Model.Nombre @Model.Apellido</h2>
    <div class="userName">
        <h3>@Model.Equipo | @Model.MiPuesto()</h3>
        <p>@Model.Email - Incorporado: @Model.FechaIncorporacion.ToShortDateString()</p>
    </div>
</section>

@await Html.PartialAsync("_GastoDisplay")

@if (Equipo != null)
{
    <section class="teamTable">
        <h3>Equipo a mi cargo</h3>
        <table>
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Puesto</th>
                    <th>Fecha de incoorporacion</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Usuario u in Equipo)
                {
                    if (u.Email != Model.Email)
                    {
                        <tr>
                            <td>@u.Email</td>
                            <td>@u.Nombre</td>
                            <td>@u.Apellido</td>
                            <td>@u.MiPuesto()</td>
                            <td>@u.FechaIncorporacion.ToShortDateString()</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>

}


<style>
    .userDisplay {
        display: flex;
        /* flex-direction: column; */
        align-items: center;
        gap: 2rem;
        margin-bottom: var(--gap-l);
    }

        .userDisplay H3 {
            margin-bottom: 0;
        }

        .userDisplay h2 {
            font-size: 3rem;
            margin-bottom: 0;
        }

        .userDisplay span {
            font-weight: bold;
        }

    .teamTable {
        margin-top: var(--gap-l)
    }

        .teamTable h3 {
            text-align: center;
        }
</style>